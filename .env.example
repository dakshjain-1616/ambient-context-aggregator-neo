# ─── LLM provider (pick one or both) ─────────────────────────────────────────
# Anthropic API key — enables Claude-powered context compression.
# Without this (and without OPENROUTER_API_KEY), the app runs in mock mode.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Which Claude model to use for context compression.
# Latest models: claude-sonnet-4-6  |  claude-opus-4-6  |  claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# OpenRouter API key — alternative/fallback LLM provider (openrouter.ai).
# If ANTHROPIC_API_KEY is set, OpenRouter is used as fallback on failure.
# OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter model to use. Latest recommended models (2026-03):
#   Budget/fast : mistralai/mistral-small-2603  |  openai/gpt-5.4-nano  |  openai/gpt-5.4-mini
#   Balanced    : xiaomi/mimo-v2-pro  |  minimax/minimax-m2.7
#   Premium     : openai/gpt-5.4  |  x-ai/grok-4.20-beta
#   Free tier   : nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL=mistralai/mistral-small-2603

# ─── File watcher ─────────────────────────────────────────────────────────────
# Root directory to watch for file changes. Default: current directory.
WATCH_DIR=.

# ─── Git ──────────────────────────────────────────────────────────────────────
# Path to the git repository to scrape commits from. Default: current directory.
GIT_REPO_PATH=.

# Maximum number of git commits to retrieve. Default: 10
MAX_COMMITS=10

# ─── Terminal history ──────────────────────────────────────────────────────────
# Override the shell history file path. Auto-detected if not set.
# HISTORY_FILE=/home/user/.zsh_history

# Maximum number of history lines to parse. Default: 100
MAX_HISTORY_LINES=100

# ─── Meeting notes ─────────────────────────────────────────────────────────────
# Directory to scan for Markdown meeting notes. Default: auto-detect.
# NOTES_DIR=/home/user/notes

# How far back to look for notes, in hours. Default: 48
NOTES_SINCE_HOURS=48

# Maximum number of notes to include. Default: 10
MAX_NOTES=10

# Maximum number of notes files for the notes_ingester module. Default: 10
NOTES_MAX_FILES=10

# Maximum age in days for notes_ingester to consider a file recent. Default: 7
NOTES_MAX_AGE_DAYS=7

# ─── Context compression ──────────────────────────────────────────────────────
# Target token budget for the compressed context. Default: 600
CONTEXT_MAX_TOKENS=600

# Cache TTL in seconds before context is re-generated. Default: 300 (5 min)
CONTEXT_CACHE_TTL=300

# LLM retry settings
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0

# ─── Activity timeline ─────────────────────────────────────────────────────────
# Default number of hours to show in the timeline view. Default: 8
TIMELINE_HOURS=8

# ─── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database. Default: ~/.ambient_context/context.db
# DB_PATH=/tmp/ambient_context.db

# ─── API server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Gradio dashboard ─────────────────────────────────────────────────────────
GRADIO_HOST=0.0.0.0
GRADIO_PORT=7860
